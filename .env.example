# =============================================================================
# CineWave — Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in the values.
# NEVER commit the actual .env file to version control.
# =============================================================================

# --- Database (PostgreSQL) ---
POSTGRES_USER=cinewave
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=cinewave_db
DATABASE_URL=postgresql+asyncpg://cinewave:CHANGE_ME@localhost:5432/cinewave_db
DATABASE_URL_SYNC=postgresql+psycopg2://cinewave:CHANGE_ME@localhost:5432/cinewave_db

# --- Authentication (JWT) ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME_GENERATE_A_RANDOM_SECRET

# --- TMDB API ---
API_KEY=your_tmdb_api_key_here

# --- AI Services (at least one required for Eco assistant) ---
GEMINI_API_KEY=your_gemini_key_here
GEMINI_API_KEY_2=optional_backup_key
GROQ_API_KEY=your_groq_key_here

# --- Admin Seed Account ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
ADMIN_EMAIL=admin@example.com

# --- Application ---
DEBUG=false
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
