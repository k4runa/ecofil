# ==========================================================================
# .gitignore — CineWave API
# ==========================================================================

# --- Python bytecode & caches ---
__pycache__/
*.py[cod]
*$py.class

# --- Testing ---
.pytest_cache/
.ruff_cache/

# --- Virtual environments ---
venv/
.venv/
env/

# --- Secrets (NEVER commit these) ---
.env

# --- Database files (regenerated at runtime) ---
*.db
*.sqlite3
database/

# --- IDE / OS specific ---
.vscode/
.idea/
.DS_Store

# --- ML model weights (if any) ---
*.pt
*.pth
